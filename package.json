{
  "name": "nest-boilerplate",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "db:deploy": "npx prisma migrate deploy && npx prisma generate",
    "docker-dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker-dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker-prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker-prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker-prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "nestjs-pino": "^4.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pino": "^10.1.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "prisma": "7.2.0",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
