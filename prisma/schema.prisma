generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  MEMBER
}

enum Status {
  DRAFT
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Frequency {
  DAILY
  WEEKLY
}

model User {
  id         String    @id @default(uuid())
  firstName  String
  lastName   String
  email      String    @unique
  password   String
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  groupMembers    GroupMember[]
  requestMembers  RequestMember[]
  assignedTasks   Task[]          @relation("AssignedTasks")
  approvalsSubmit Approval[]      @relation("SubmitApproval")
  approvalsReview Approval[]      @relation("ReviewApproval")
  recurringTasks  RecurringTask[]
  projects        Project[]       @relation("ProjectPIC")
  ownedProjects   Project[]       @relation("ProjectOwner")

  @@map("users")
}

model Project {
  id             String    @id @default(uuid())
  projectName    String
  description    String
  coverImage     String?
  progressStatus Status    @default(DRAFT)
  overviews      String?
  ownerId        String
  picId          String?
  deadline       DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  owner          User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  pic            User?           @relation("ProjectPIC", fields: [picId], references: [id])
  groups         Group[]
  tasks          Task[]
  requestMembers RequestMember[]

  @@map("projects")
}

model Group {
  id        String    @id @default(uuid())
  title     String
  projectId String
  totalKpi  Int?
  isStrict  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project        Project         @relation(fields: [projectId], references: [id])
  recurringTasks RecurringTask[]
  tasks          Task[]
  members        GroupMember[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  userId    String
  groupId   String
  role      Role
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@map("group_members")
}

model RequestMember {
  id        String    @id @default(uuid())
  userId    String
  projectId String
  role      Role
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@map("request_members")
}

model Task {
  id            String    @id @default(uuid())
  projectId     String
  groupId       String?
  title         String
  description   String?
  status        Status    @default(TODO)
  priorityLevel Int?
  assigneeId    String
  startDate     DateTime?
  dueDate       DateTime?
  taskActivity  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  project  Project @relation(fields: [projectId], references: [id])
  group    Group?  @relation(fields: [groupId], references: [id])
  assignee User    @relation("AssignedTasks", fields: [assigneeId], references: [id])

  approvals Approval[]

  @@map("tasks")
}

model RecurringTask {
  id        String    @id @default(uuid())
  name      String
  assignTo  String
  groupId   String
  frequency Frequency
  interval  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User  @relation(fields: [assignTo], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@map("recurring_tasks")
}

model Approval {
  id         String    @id @default(uuid())
  taskId     String
  submitById String
  isApproved Boolean   @default(false)
  reviewById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  task   Task  @relation(fields: [taskId], references: [id])
  submit User  @relation("SubmitApproval", fields: [submitById], references: [id])
  review User? @relation("ReviewApproval", fields: [reviewById], references: [id])

  @@map("approvals")
}
