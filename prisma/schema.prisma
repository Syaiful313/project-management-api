generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String     @id @default(uuid())
  firstName  String
  lastName   String
  email      String     @unique
  password   String
  role       SystemRole @default(USER)
  isVerified Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  groupMembers    GroupMember[]
  projectMembers  ProjectMember[]
  requestMembers  RequestMember[]
  assignedTasks   Task[]          @relation("AssignedTasks")
  approvalsSubmit Approval[]      @relation("SubmitApproval")
  approvalsReview Approval[]      @relation("ReviewApproval")
  recurringTasks  RecurringTask[]
  createdProjects Project[]       @relation("ProjectCreator")

  @@map("users")
}

enum SystemRole {
  SUPER_ADMIN
  USER
}

model Project {
  id             String    @id @default(uuid())
  projectName    String
  description    String
  coverImage     String?
  progressStatus Status    @default(DRAFT)
  overviews      String?
  creatorId      String
  deadline       DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  creator        User            @relation("ProjectCreator", fields: [creatorId], references: [id])
  members        ProjectMember[]
  groups         Group[]
  tasks          Task[]
  requestMembers RequestMember[]

  @@map("projects")
}

enum Status {
  DRAFT
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model Group {
  id        String    @id @default(uuid())
  title     String
  projectId String
  totalKpi  Int?
  isStrict  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project        Project         @relation(fields: [projectId], references: [id])
  recurringTasks RecurringTask[]
  tasks          Task[]
  members        GroupMember[]
  requestMembers RequestMember[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  userId    String
  groupId   String
  role      GroupRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@map("group_members")
}

enum GroupRole {
  ADMIN
  SUPERVISOR
  MEMBER
}

model ProjectMember {
  id        String      @id @default(uuid())
  userId    String
  projectId String
  role      ProjectRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@map("project_members")
}

enum ProjectRole {
  OWNER
  PIC
  MEMBER
  VIEWER
}

model RequestMember {
  id          String        @id @default(uuid())
  userId      String
  projectId   String?
  groupId     String?
  projectRole ProjectRole?
  groupRole   GroupRole?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  group   Group?   @relation(fields: [groupId], references: [id])

  @@map("request_members")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Task {
  id            String    @id @default(uuid())
  projectId     String
  groupId       String?
  title         String
  description   String?
  status        Status    @default(TODO)
  priorityLevel Int?
  assigneeId    String
  startDate     DateTime?
  dueDate       DateTime?
  taskActivity  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  project  Project @relation(fields: [projectId], references: [id])
  group    Group?  @relation(fields: [groupId], references: [id])
  assignee User    @relation("AssignedTasks", fields: [assigneeId], references: [id])

  approvals Approval[]

  @@map("tasks")
}

model RecurringTask {
  id        String    @id @default(uuid())
  name      String
  assignTo  String
  groupId   String
  frequency Frequency
  interval  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User  @relation(fields: [assignTo], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@map("recurring_tasks")
}

enum Frequency {
  DAILY
  WEEKLY
}

model Approval {
  id         String    @id @default(uuid())
  taskId     String
  submitById String
  isApproved Boolean   @default(false)
  reviewById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  task   Task  @relation(fields: [taskId], references: [id])
  submit User  @relation("SubmitApproval", fields: [submitById], references: [id])
  review User? @relation("ReviewApproval", fields: [reviewById], references: [id])

  @@map("approvals")
}
